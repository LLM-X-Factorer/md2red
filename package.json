{
  "name": "md2red",
  "version": "0.2.0",
  "description": "Markdown to Xiaohongshu (RED) image-text note converter & publisher",
  "type": "module",
  "bin": {
    "md2red": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:e2e": "npx playwright test",
    "test:all": "npm test && npm run test:e2e",
    "build:web": "cd web && npx vite build",
    "build:all": "npm run build && npm run build:web",
    "start:web": "node dist/web/server.js",
    "dev:web": "cd web && npx vite dev --port 5173"
  },
  "keywords": [
    "xiaohongshu",
    "red",
    "markdown",
    "image",
    "cli"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "@types/busboy": "^1.5.4",
    "busboy": "^1.6.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-to-string": "^4.0.0",
    "nanoid": "^5.1.2",
    "openai": "^6.33.0",
    "ora": "^8.2.0",
    "playwright": "^1.50.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "react-router": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^8.0.3"
  }
}
